# @steambalance/booster-framework is published to GitHub Packages, which
# requires auth even for public packages. Set NODE_AUTH_TOKEN to a personal
# access token (classic) with `read:packages`, or put the token directly in
# your user ~/.npmrc. See README "Установка".
@steambalance:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
